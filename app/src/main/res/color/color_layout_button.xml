<?xml version="1.0" encoding="utf-8"?>
<!--
    Color state list para os botões de layout da barra inferior.
    Usado em android:imageTintList e android:textColor dos botões.
    Estado selecionado → cor primária (roxo)
    Estado normal      → cinza
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true"  android:color="@color/primary" />
    <item android:state_pressed="true"   android:color="@color/primary" />
    <item                                android:color="@color/layout_btn_normal" />
</selector>
