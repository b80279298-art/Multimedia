<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema principal — Material Design 3 Dark -->
    <style name="Theme.DualStreamPlayerPro" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_variant</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <!-- Ocultar ActionBar padrão (usamos barra customizada) -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <!-- Fundo da janela preto para a área de vídeo -->
        <item name="android:windowBackground">@color/background</item>
        <!-- Sem animation de entrada/saída da Activity -->
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- ══════════════════════════════════════
         Estilos dos botões de layout na barra inferior
    ══════════════════════════════════════ -->

    <!-- Container do botão de layout (LinearLayout vertical) -->
    <style name="LayoutButton">
        <item name="android:layout_width">72dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <!-- Label do botão de layout -->
    <style name="LayoutButtonLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:gravity">center</item>
    </style>

</resources>
