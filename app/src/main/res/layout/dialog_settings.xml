<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_settings.xml
    Diálogo de configurações completo do DualStreamPlayer Pro.
    Inclui: URLs das streams, volumes individuais, configurações de rede,
    múltiplos áudios e seleção do player principal.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:divider="?android:attr/listDivider"
        android:showDividers="middle">

        <!-- ══════════════════════════════════════
             SEÇÃO: URLs DAS STREAMS
        ══════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_streams"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <!-- Stream 1 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/settings_stream_url_1"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStream1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:singleLine="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Stream 2 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/settings_stream_url_2"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStream2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:singleLine="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Stream 3 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/settings_stream_url_3"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStream3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:singleLine="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Stream 4 -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/settings_stream_url_4"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStream4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:singleLine="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══════════════════════════════════════
             SEÇÃO: VOLUME INDIVIDUAL
        ══════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_volume"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Volume Player 1 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_volume_1"
            android:textAppearance="?attr/textAppearanceBodySmall" />
        <com.google.android.material.slider.Slider
            android:id="@+id/sliderVolume1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="100"
            android:stepSize="1"
            android:value="100"
            android:layout_marginBottom="4dp" />

        <!-- Volume Player 2 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_volume_2"
            android:textAppearance="?attr/textAppearanceBodySmall" />
        <com.google.android.material.slider.Slider
            android:id="@+id/sliderVolume2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="100"
            android:stepSize="1"
            android:value="100"
            android:layout_marginBottom="4dp" />

        <!-- Volume Player 3 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_volume_3"
            android:textAppearance="?attr/textAppearanceBodySmall" />
        <com.google.android.material.slider.Slider
            android:id="@+id/sliderVolume3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="100"
            android:stepSize="1"
            android:value="100"
            android:layout_marginBottom="4dp" />

        <!-- Volume Player 4 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_volume_4"
            android:textAppearance="?attr/textAppearanceBodySmall" />
        <com.google.android.material.slider.Slider
            android:id="@+id/sliderVolume4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="100"
            android:stepSize="1"
            android:value="100"
            android:layout_marginBottom="16dp" />

        <!-- ══════════════════════════════════════
             SEÇÃO: ÁUDIO
        ══════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_audio"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Switch: múltiplos áudios -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchMultiAudio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_multi_audio"
            android:checked="true"
            android:layout_marginBottom="8dp" />

        <!-- Spinner: player principal -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_primary_player"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:layout_marginBottom="4dp" />
        <Spinner
            android:id="@+id/spinnerPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- ══════════════════════════════════════
             SEÇÃO: REDE E BUFFER
        ══════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_network"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Switch: reconexão automática -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchAutoReconnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_auto_reconnect"
            android:checked="true"
            android:layout_marginBottom="8dp" />

        <!-- Buffer (ms) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/settings_buffer_ms"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="8dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBuffer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:singleLine="true"
                android:text="5000" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Timeout de rede (ms) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/settings_timeout_ms"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTimeout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:singleLine="true"
                android:text="15000" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>
